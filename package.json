{
  "name": "quote-locator",
  "version": "0.1.0",
  "description": "Find claimed quotes inside source text with exact, normalized, and fuzzy matching.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pixelbrew-studio/quote-locator.git"
  },
  "homepage": "https://github.com/pixelbrew-studio/quote-locator#readme",
  "bugs": {
    "url": "https://github.com/pixelbrew-studio/quote-locator/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "quote-locator": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "citations",
    "quotes",
    "fuzzy-matching",
    "typescript",
    "ai-tools"
  ],
  "license": "MIT",
  "author": "Pixelbrew Studio (https://pixelbrew.studio)",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
